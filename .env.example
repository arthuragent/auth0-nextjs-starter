# Copy to .env.local and fill in values from the Auth0 Dashboard (Regular Web Application).

# Required — encrypts session and transaction cookies (openssl rand -hex 32)
AUTH0_SECRET=

# Required — tenant domain, e.g. dev-abc123.us.auth0.com
AUTH0_DOMAIN=

# Required — application Client ID and Client Secret
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Recommended — canonical app URL (local: http://localhost:3000). Omit on Vercel previews to infer host.
APP_BASE_URL=http://localhost:3000

# Optional — API audience when you need access tokens for your backend (Resource Server identifier)
# AUTH0_AUDIENCE=
